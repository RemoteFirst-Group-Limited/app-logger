{
    "name": "remotefirst-group-limited/app-logger",
    "description": "Строгая обёртка AppLogger для Laravel с обязательной передачей index_name.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0",
        "psr/log": "^2.0|^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "pestphp/pest": "^2.36"
    },
    "autoload": {
        "psr-4": {
            "AppLogger\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AppLogger\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AppLogger\\Providers\\AppLoggerServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
